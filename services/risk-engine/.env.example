KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=fraud.events.v1
KAFKA_GROUP_ID=risk-engine-v1
WORKER_BUFFER=256
PROCESS_TIMEOUT=5s
RISK_ALERTS_TOPIC=fraud.risk-alerts.v1
RISK_ALERT_THRESHOLD=50
ENABLE_RISK_ALERTS=true

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fraud
REDIS_FAILED_LOGIN_KEY=user:{id}:failed_login
REDIS_LOCATIONS_KEY=user:{id}:locations
REDIS_TRANSACTIONS_KEY=user:{id}:transactions
FAILED_LOGIN_TTL=24h
LOCATION_TTL=720h
TRANSACTIONS_TTL=720h
RECENT_TRANSACTIONS_MAX_SIZE=50

RULE_FAILED_LOGIN_BURST_THRESHOLD=3
RULE_FAILED_LOGIN_BURST_SCORE=30
RULE_NEW_DEVICE_SCORE=20
RULE_IMPOSSIBLE_TRAVEL_SCORE=50
RULE_IMPOSSIBLE_TRAVEL_MAX_SPEED_KMPH=900
RULE_IMPOSSIBLE_TRAVEL_MIN_DISTANCE_KM=500
RULE_TRANSACTION_SPIKE_SCORE=40
RULE_TRANSACTION_SPIKE_MIN_SAMPLES=3
RULE_TRANSACTION_SPIKE_MULTIPLIER=3
