FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /bin/event-generator ./cmd/event-generator

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/event-generator /event-generator
EXPOSE 8080
ENTRYPOINT ["/event-generator"]
